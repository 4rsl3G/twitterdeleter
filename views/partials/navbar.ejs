<nav class="navbar">
  <div class="nav-container">
    <a href="/" class="nav-logo">
      <span class="logo-icon"><i class="ri-skull-2-fill"></i></span>
      <span class="logo-text">Tweet<span class="logo-accent">Reaper</span></span>
    </a>

    <div class="nav-links">
      <a href="/" class="nav-link">Home</a>
      <% if (isAuth && user) { %>
        <a href="/dashboard" class="nav-link">Dashboard</a>
        <div class="nav-user">
          <% if (user.profileImage) { %>
            <img src="<%= user.profileImage %>" alt="<%= user.name %>" class="nav-avatar" />
          <% } else { %>
            <div class="nav-avatar-ph"><i class="ri-user-fill"></i></div>
          <% } %>
          <span class="nav-uname">@<%= user.username %></span>
          <a href="/auth/logout" class="nav-logout" title="Logout"><i class="ri-logout-box-r-line"></i></a>
        </div>
      <% } else { %>
        <a href="/auth/login" class="nav-link nav-link-cta">
          <i class="ri-twitter-x-fill"></i> Connect Twitter
        </a>
      <% } %>
    </div>

    <button class="nav-burger" id="navBurger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav-mobile" id="navMobile">
    <a href="/" class="nav-mobile-link">Home</a>
    <% if (isAuth && user) { %>
      <a href="/dashboard" class="nav-mobile-link">Dashboard</a>
      <a href="/auth/logout" class="nav-mobile-link nav-mobile-logout">
        <i class="ri-logout-box-r-line"></i> Logout (@<%= user.username %>)
      </a>
    <% } else { %>
      <a href="/auth/login" class="nav-mobile-link nav-mobile-connect">
        <i class="ri-twitter-x-fill"></i> Connect Twitter
      </a>
    <% } %>
  </div>
</nav>
